#!/usr/bin/env bash
# sesh-pick — sesh list decorated with Claude-state indicators, piped to fzf.
# Glyphs: ● active  ◐ awaiting-input  ○ idle/non-claude  · configured, not running
set -eo pipefail

status_for() {
  local name="$1"
  tmux has-session -t "$name" 2>/dev/null || { echo "·"; return; }
  local pane
  pane=$(tmux capture-pane -pt "$name" -S -30 2>/dev/null || true)
  # Claude Code UI strings — update if/when Anthropic rewords them.
  case "$pane" in
    *"esc to interrupt"*)        echo "●" ;;
    *"Do you want"*|*"❯ 1."*)    echo "◐" ;;
    *)                            echo "○" ;;
  esac
}

# Tab delimiter preserves names that contain spaces.
decorate() {
  while IFS= read -r name; do
    printf '%s\t%s\n' "$(status_for "$name")" "$name"
  done < <(sesh list)
}

selection=$(decorate | fzf --delimiter=$'\t' --with-nth=1,2 \
                           --prompt='sesh> ' --height=60% --reverse) || exit 0
exec sesh connect "${selection#*$'\t'}"
