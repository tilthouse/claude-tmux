#!/usr/bin/env ruby
# frozen_string_literal: true

# claude-tmux — tmux session launcher for Claude Code.
# Invocation-name dispatch: runs as cct (project), ccg (group), ccs (picker),
# or as `claude-tmux <subcommand>`.

bin_path  = File.realpath(__FILE__)
repo_root = File.expand_path('../..', bin_path)
lib_path  = File.join(repo_root, 'lib')
gemfile   = File.join(repo_root, 'Gemfile')

if File.directory?(lib_path)
  $LOAD_PATH.unshift(lib_path)
  if File.file?(gemfile)
    ENV['BUNDLE_GEMFILE'] ||= gemfile
    begin
      require 'bundler/setup'
    rescue LoadError
      # Bundler not installed; fall through to system gems.
    end
  end
end

require 'claude_tmux'

exit(ClaudeTmux::CLI.new($PROGRAM_NAME, ARGV).run || 0)
